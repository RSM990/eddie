# eddie environment — copy to .env and fill in. NEVER commit .env.

# v2 target DB via the scoped eddie_etl login (see scripts/eddie_etl.sql).
# SQLAlchemy + pyodbc + SQL Server (ODBC Driver 18). On Mac, install msodbcsql18.
DB_URL=mssql+pyodbc://eddie_etl:CHANGE_ME@localhost:1433/TheWAC_v2?driver=ODBC+Driver+17+for+SQL+Server&TrustServerCertificate=yes

# Fixed UUID namespace for uuid5(namespace, ProReferenceKey) on new players.
# Keep this CONSTANT forever — changing it re-IDs every future rookie.
ID_NAMESPACE=6f1d4f2a-7c3e-4b9a-9e21-0a5c6d8e1f23

USER_AGENT=eddie-etl-bot/1.0

# How to fetch Cloudflare-gated PFR pages (DEC-005).
#   api     -> scraping API (default; cloud/Azure — set the SCRAPER_* vars below)
#   browser -> real/attached Chrome (local dev; export CHROME_DEBUGGER_ADDRESS)
FETCH_MODE=api
SCRAPER_PROVIDER=scraperapi
SCRAPER_API_KEY=CHANGE_ME
# SCRAPER_RENDER_JS=true
# SCRAPER_TIMEOUT=90
